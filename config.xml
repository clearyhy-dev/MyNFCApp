<?xml version='1.0' encoding='utf-8'?>
<widget id="com.nfclock.nfcapp" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>My NFC App</name>
    <description>Sample Apache Cordova App</description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">
        Apache Cordova Team
    </author>
    <content src="resources/index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="http://*/*" />
    <allow-navigation href="https://*/*" />
    <access origin="*" />
    <allow-intent href="*" />
    
    <!-- Android调试配置 -->
    <platform name="android">
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="33" />
        <preference name="android-usesCleartextTraffic" value="true" />
        <preference name="android-installLocation" value="auto" />
        <!-- 允许WebView调试 -->
        <preference name="webview-debugging-enabled" value="true" />
    </platform>
</widget>
